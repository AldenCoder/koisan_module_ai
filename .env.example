# MongoDB
MONGO_URI=mongodb://localhost:27017/sengvang

# App environment
ENVIRONMENT=development
ENABLE_API_V0=true
ENABLE_API_V1=true
RATE_LIMIT=5/minute
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Mail
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_character_app_password
MAIL_FROM=your_email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# Frontend
FRONTEND_URL=http://localhost:3000

# Local base URL used by the Facebook webhook workflow callback
BASE_URL=https://koisanmoduleai-production.up.railway.app

# Optional dedicated callback base URL for workflow self-call
# If set, webhook workflow will use this value first.
WORKFLOW_BASE_URL=http://localhost:8000

# AI conversation versioning
# Existing conversations without version are treated as 1.0.
AI_CONVERSATION_VERSION=1.1

# JWT / auth helpers
SECRET_KEY=change_me
OPENAI_API_KEY=change_me
ALGORITHM=HS256
ADMIN_ROLE_NAME=Quản trị hệ thống
DEFAULT_ROLE_NAME=Người dùng

# Google Drive image lookup used by social image replies
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key
GOOGLE_DRIVE_FOLDER_LOOKUP_MAX_DEPTH=3

# Facebook Messenger webhook
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FB_PAGE_ID=your_facebook_page_id
FB_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
FB_SENDER_BUFFER_SECONDS=15
FB_ADMIN_TAKEOVER_PAUSE_MINUTES=10
FB_AI_CHAT_URL=https://openclaw-production-ecec.up.railway.app/api/chat
FB_AI_BEARER_TOKEN=your_openclaw_ai_bearer_token
FB_AI_RETRY_ATTEMPTS=3
FB_AI_RETRY_BACKOFF_SECONDS=1
FB_AI_REQUEUE_DELAY_SECONDS=10

# Pancake webhook / Public API
# JSON one-line mapping. Each Pancake page_id must have its own token.
PANCAKE_PAGE_ACCESS_TOKENS_BY_PAGE_ID='{"970198996185881":"replace_with_page_970198996185881_token","tt_6711731671916708866":"replace_with_page_tt_6711731671916708866_token"}'
# Deprecated for multi-page Pancake webhook. Do not use as fallback.
# PANCAKE_PAGE_ACCESS_TOKEN=
PANCAKE_API_TIMEOUT_SECONDS=30
PANCAKE_API_RETRY_ATTEMPTS=3
PANCAKE_API_RETRY_BACKOFF_SECONDS=1
PANCAKE_ADMIN_TAKEOVER_PAUSE_MINUTES=10
PANCAKE_SENDER_BUFFER_SECONDS=5
PANCAKE_HANDOVER_CONTEXT_MAX_MESSAGES=30
PANCAKE_AUTO_CONSULT_ENABLED=false
PANCAKE_COMMENT_AUTO_REPLY_ENABLED=false
PANCAKE_AUTO_CONSULT_PRODUCT_CODE_REGEX=(?<![A-Za-z0-9])(?:[A-Za-z]?\d{6,8})(?:(?:[A-Za-z0-9]{1,3})|(?:[^\S\r\n]*-[^\S\r\n]*[A-Za-z0-9]{1,3}))?(?![A-Za-z0-9])
PANCAKE_IMAGE_CACHE_PATH=storage/pancake_image_cache.json
PANCAKE_IMAGE_STORAGE_DIR=storage/pancake_images
PANCAKE_INBOX_IMAGE_MAX_COUNT=3
PANCAKE_COMMENT_IMAGE_MAX_COUNT=3
PANCAKE_IMAGE_DOWNLOAD_TIMEOUT_SECONDS=15
PANCAKE_IMAGE_UPLOAD_TIMEOUT_SECONDS=30
PANCAKE_IMAGE_MAX_BYTES=10485760
PANCAKE_IMAGE_STORAGE_MAX_BYTES=500000
PANCAKE_REUSE_UPLOADED_CONTENT_ID=true
PANCAKE_DRIVE_IMAGE_SELECTION_STRATEGY=color_diverse
PANCAKE_DRIVE_COLOR_FOLDER_MAX_COUNT=5

# Image assets storage
RAG_IMAGE_STORAGE_DIR=storage/rag_images
RAG_IMAGE_PUBLIC_PATH=/rag-images
RAG_IMAGE_TARGET_MAX_BYTES=1000000

# Crop-aware image search
CHROMA_PERSIST_DIR=data/chroma
CHROMA_IMAGE_SEARCH_COLLECTION=image_search_crop_views_v1
CLIP_CROP_AWARE_SOURCE_DIR=data/source_images
CLIP_CROP_AWARE_FOREGROUND_DIR=data/foregrounds
CLIP_CROP_AWARE_METADATA_PATH=data/source_images_metadata.csv
PUBLIC_IMAGE_CROP_SEARCH_TIMEOUT_SECONDS=15
PUBLIC_IMAGE_CROP_SEARCH_MAX_BYTES=10485760
PUBLIC_IMAGE_CROP_SEARCH_MIN_CONFIDENCE=0.9
